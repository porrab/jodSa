# JodSa environment — copy to .env.local and fill in. NEVER commit real secrets.

# --- App origin (absolute redirect URLs, e.g. Supabase signup email confirmation) ---
# Local dev: http://localhost:3000  ·  Production: the real Vercel domain (no trailing slash).
# Must also be added to Supabase → Authentication → URL Configuration → Redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (runtime user-data access via supabase-js + user session; RLS enforced) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Migrations ONLY (Drizzle / drizzle-kit) — bypasses RLS, never use on a request path ---
# Direct Postgres connection string from the Supabase dashboard (Project Settings → Database).
DATABASE_URL=

# Service role key — trusted server-only / migration use ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
